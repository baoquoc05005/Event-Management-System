@model EventManagementSystem.Models.Event

<div class="container mt-4">

    <h1 class="mb-3 text-danger">Delete Event</h1>

    <h4>Are you sure you want to delete this?</h4>

    <div class="mb-3">
        <p><strong>Title:</strong> @Model.Title</p>
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Location:</strong> @Model.Location</p>
        <p><strong>Event Date:</strong> @Model.EventDate</p>
        <p><strong>Capacity:</strong> @Model.Capacity</p>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="EventId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </form>

</div>