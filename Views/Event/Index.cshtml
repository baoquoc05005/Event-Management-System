@model IEnumerable<EventManagementSystem.Models.Event>

<div class="container mt-4">

    <h1 class="mb-3">Events</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    </p>

    <form method="get" class="mb-3">
        <input type="text" name="searchString" placeholder="Search events" class="form-control w-25 d-inline" />
        <button type="submit" class="btn btn-secondary ms-2">Search</button>
    </form>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Location</th>
                <th>Event Date</th>
                <th>Capacity</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>@item.Location</td>
                    <td>@item.EventDate</td>
                    <td>@item.Capacity</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.EventId" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.EventId" class="btn btn-info btn-sm">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.EventId" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>