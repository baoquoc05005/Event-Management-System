@model IEnumerable<EventManagementSystemFinal.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Event Categories</h2>
        <a asp-action="Create" class="btn btn-primary">Create New Category</a>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Events</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>@item.Events.Count</td>
                    <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
