@model EventManagementSystemFinal.Models.Registration
@{
    ViewData["Title"] = "Cancel Registration";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h3>Cancel Registration</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i> Are you sure you want to cancel your registration for this event?
                    </div>
                    
                    <dl class="row">
                        <dt class="col-sm-3">Event</dt>
                        <dd class="col-sm-9">@Model.Event.Title</dd>
                        
                        <dt class="col-sm-3">Date</dt>
                        <dd class="col-sm-9">@Model.Event.EventDate.ToString("MMMM dd, yyyy")</dd>
                        
                        <dt class="col-sm-3">Location</dt>
                        <dd class="col-sm-9">@Model.Event.Location</dd>
                        
                        <dt class="col-sm-3">Registered On</dt>
                        <dd class="col-sm-9">@Model.RegistrationDate.ToString("MMMM dd, yyyy")</dd>
                        
                        @if (!string.IsNullOrEmpty(Model.Notes))
                        {
                            <dt class="col-sm-3">Notes</dt>
                            <dd class="col-sm-9">@Model.Notes</dd>
                        }
                    </dl>
                    
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="RegistrationId" />
                        <button type="submit" class="btn btn-danger">Cancel Registration</button>
                        <a asp-action="Index" class="btn btn-secondary">Keep Registration</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
